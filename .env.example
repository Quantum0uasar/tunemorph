# TuneMorph environment variables
# Copy this to .env and fill in values

# App environment
TUNEMORPH_ENV=development   # development | production

# Backend server
HOST=0.0.0.0
PORT=8000

# Optional: OpenAI key for future GPT-powered lesson generation
# OPENAI_API_KEY=sk-...

# Optional: max upload size in bytes (default 20 MB)
MAX_UPLOAD_BYTES=20971520

# Optional: recordings storage dir (defaults to system temp)
# RECORDINGS_DIR=/var/tunemorph/recordings
